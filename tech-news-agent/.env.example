# --- App ---
APP_ENV=dev
SERVICE_VERSION=0.1.0
LOG_LEVEL=INFO

# --- LINE Messaging API ---
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_IDS=                         # CSV of recipient LINE userIds

# --- LLM (via llm-client) ---
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic                 # anthropic | vertex
LLM_MODEL=claude-haiku-4-5             # Haiku for Phase 1 cost optimization
LLM_MODEL_HEAVY=claude-sonnet-4-6      # Sonnet for Phase 2 QA (reserved)
LLM_MAX_TOKENS=1024
LLM_MOCK_MODE=false
GOOGLE_CLOUD_PROJECT=                  # Vertex AI のみ
VERTEX_REGION=us-east5

# --- Pipeline ---
PIPELINE_SOURCES_PATH=./config/sources.yaml
RELEVANCE_THRESHOLD=5.0                # final_score = llm_score * source_weight の通過閾値
DEDUP_WINDOW_DAYS=30
TECH_NEWS_DB_PATH=./data/tech_news.db
TOP_NEWS_N=5                           # 技術ニューストラック
TOP_ARXIV_N=2                          # arXiv トラック

# --- analytics-platform ---
ANALYTICS_ENABLED=true
ANALYTICS_SERVICE_NAME=tech-news-agent
ANALYTICS_DATA_DIR=../analytics-platform/data
ANALYTICS_COMPRESS=false
ANALYTICS_CONTENT_INLINE_THRESHOLD_BYTES=8192

# --- OTel (optional) ---
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SAMPLING_RATIO=1.0

# --- analytics GCP backend (Phase 5 Step 10) ---
# `local` (既定、ローカル FS のみ) または `gcs` (Cloud Run + Workload Identity)
ANALYTICS_STORAGE_BACKEND=local

# `gcs` 指定時のみ意味を持つ env (analytics_platform.gcp_config が読む)
# GCS バケットは analytics-platform/terraform/gcs.tf で作成済の名前を入れる
ANALYTICS_GCS_BUCKET=
ANALYTICS_GCS_RAW_PREFIX=uploaded/
ANALYTICS_GCS_PAYLOAD_PREFIX=payloads/
ANALYTICS_GCP_PROJECT=

# 周期的に LocalUploader.run_once() を回す間隔 (秒)
# 0 以下にすると shutdown 時のみ 1 回 upload する
ANALYTICS_UPLOAD_INTERVAL_SECONDS=300
