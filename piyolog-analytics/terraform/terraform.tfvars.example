################################################################################
# terraform.tfvars 例。`cp terraform.tfvars.example terraform.tfvars` で複製し、
# 実際の値で埋めること。`terraform.tfvars` は git に commit しない (.gitignore 済)。
################################################################################

# 必須
project_id = "your-gcp-project-id"

# 推奨デフォルト (必要に応じて上書き)
region      = "us-central1"
name_prefix = "piyolog"

# Cloud SQL 構成 (家族用は db-f1-micro / ZONAL で月 ~$10)
# cloud_sql_tier             = "db-f1-micro"
# cloud_sql_database_version = "POSTGRES_15"
# cloud_sql_disk_size        = 10
# cloud_sql_availability     = "ZONAL"
# cloud_sql_backup_enabled   = true
# cloud_sql_db_name          = "piyolog"
# cloud_sql_db_user          = "piyolog"

# 開発環境では false にしないと `terraform destroy` で消せない (本番は true 推奨)
cloud_sql_deletion_protection = true

# Artifact Registry
# ar_repo_name = "piyolog-analytics"

# LINE secrets の初期 version を TF で投入する場合は true にして value を埋める。
# ただし state にシークレットが書き込まれるため、本番では false 推奨で
# `gcloud secrets versions add` で手動投入する。
create_line_secret_versions = false
# line_channel_secret_value       = ""
# line_channel_access_token_value = ""
