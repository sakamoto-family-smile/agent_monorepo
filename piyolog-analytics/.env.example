# --- App ---
APP_ENV=dev                     # dev | staging | prod
SERVICE_VERSION=0.1.0
LOG_LEVEL=INFO

# --- SQLite ---
# SQLite DB 配置先。テストでは :memory: または一時ディレクトリを使う
PIYOLOG_DB_PATH=./data/piyolog.db

# --- LINE ---
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# --- Family アクセス制御 ---
# 許可する LINE userId を CSV で列挙 (夫婦 2 人分)
FAMILY_USER_IDS=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxx,Uyyyyyyyyyyyyyyyyyyyyyyyyyyyy
# 家族識別子 (Phase 1 はシングル固定)
FAMILY_ID=default

# --- 子の固定 (Phase 1) ---
DEFAULT_CHILD_ID=default

# --- analytics-platform ---
ANALYTICS_ENABLED=true
ANALYTICS_SERVICE_NAME=piyolog-analytics
ANALYTICS_DATA_DIR=./data/analytics
ANALYTICS_COMPRESS=false
ANALYTICS_CONTENT_INLINE_THRESHOLD_BYTES=8192

# --- OpenTelemetry (optional) ---
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SAMPLING_RATIO=1.0

# --- Upload limits ---
UPLOAD_MAX_BYTES=5242880        # 5MB
