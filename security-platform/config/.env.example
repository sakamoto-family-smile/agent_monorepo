# NVD API Key (required - register at https://nvd.nist.gov/developers/request-an-api-key)
# Without this key, NVD API is limited to 5 requests/30s. With key: 50 requests/30s.
NVD_API_KEY=your_nvd_api_key_here

# GitHub Personal Access Token (for Advisory API)
# Create at https://github.com/settings/tokens (read:packages scope sufficient)
GITHUB_TOKEN=your_github_token_here

# Slack Webhook URL for notifications
SLACK_WEBHOOK_URL=

# LINE Messaging API (Bot channel)
# 取得手順: LINE Developers Console → Providers → Messaging API channel 作成
#   - LINE_CHANNEL_SECRET: チャネル基本設定の Channel secret
#   - LINE_CHANNEL_ACCESS_TOKEN: Messaging API 設定の long-lived Channel access token
#   - LINE_USER_IDS: Bot を友だち追加したユーザの userId を CSV で列挙
#     例: Uxxxxxxxxxxxxxxxxxxxxxxxxxxxx,Uyyyyyyyyyyyyyyyyyyyyyyyyyyyy
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_IDS=

# LINE Notify (DEPRECATED)
# LINE Notify は 2025/03/31 にサービス終了済。設定しても無視されます。
# 互換性のため env 名は残していますが、コードパス上は deprecation 警告だけ出します。
LINE_NOTIFY_TOKEN=

# Email configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=

# LLM Analysis - set ONE of the following (Claude or Gemini via Vertex AI)
# Claude API key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Vertex AI (Gemini) - uses Application Default Credentials (no API key required)
# Run `gcloud auth application-default login` to authenticate locally.
# For production, attach a service account with roles/aiplatform.user to the instance.
VERTEX_AI_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1

# LLM provider to use for analysis: "claude" or "gemini" (default: auto-detect)
LLM_PROVIDER=

# Database path
DATABASE_URL=sqlite:///./data/security.db

# Dashboard settings
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# Proxy settings
PROXY_HOST=0.0.0.0
PROXY_PORT=8080
