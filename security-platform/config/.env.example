# NVD API Key (required - register at https://nvd.nist.gov/developers/request-an-api-key)
# Without this key, NVD API is limited to 5 requests/30s. With key: 50 requests/30s.
NVD_API_KEY=your_nvd_api_key_here

# GitHub Personal Access Token (for Advisory API)
# Create at https://github.com/settings/tokens (read:packages scope sufficient)
GITHUB_TOKEN=your_github_token_here

# Slack Webhook URL for notifications
SLACK_WEBHOOK_URL=

# LINE Notify Token
LINE_NOTIFY_TOKEN=

# Email configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=

# LLM Analysis - set ONE of the following (Claude or Gemini)
#
# Claude - choose one auth method (checked in priority order):
#   1. ANTHROPIC_API_KEY: standard API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=
#   2. ANTHROPIC_AUTH_TOKEN: Bearer token for LLM proxy/gateway
ANTHROPIC_AUTH_TOKEN=
#   3. CLAUDE_CODE_OAUTH_TOKEN: long-lived OAuth token (run: claude setup-token)
CLAUDE_CODE_OAUTH_TOKEN=

# Gemini API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# LLM provider to use for analysis: "claude" or "gemini" (default: auto-detect from keys)
LLM_PROVIDER=

# Database path
DATABASE_URL=sqlite:///./data/security.db

# Dashboard settings
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# Proxy settings
PROXY_HOST=0.0.0.0
PROXY_PORT=8080
