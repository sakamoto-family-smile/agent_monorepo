# ── Claude (Phase 1 で agent モードを使う場合のみ必須) ─────────
# Claude Code OAuth Token または Anthropic API Key
CLAUDE_CODE_OAUTH_TOKEN=

# Google Cloud (VertexAI 経由で Claude を使う場合)
GOOGLE_CLOUD_PROJECT=
VERTEX_AI_LOCATION=us-east5

# ── アプリ全般 ────────────────────────────────────────────────
APP_ENV=local
LOG_LEVEL=debug

# ── データパス (デフォルトのままで OK) ────────────────────────
# DB_PATH=data/local/hotcook.db
# DATA_DIR=data
# MENU_CATALOG_PATH=data/skills/hotcook-recipes/menu-catalog.json

# ── 分析基盤 (analytics-platform) 連携 ─────────────────────────
# false にすると AnalyticsLogger が NoOpSink になり、JSONL は書かれない
ANALYTICS_ENABLED=true

# JSONL 書込先 (デフォルト: hotcook-agent 自身の data 配下)
ANALYTICS_DATA_DIR=./data/analytics

# 業務ログ送信時の service_name (Hive パーティションキー)
ANALYTICS_SERVICE_NAME=hotcook-agent

# JSONL の gzip 圧縮 (local は false 推奨、デバッグしやすい)
ANALYTICS_COMPRESS=false

# コンテンツ inline / URI 振り分け閾値 (bytes)
ANALYTICS_CONTENT_INLINE_THRESHOLD_BYTES=8192

# OTel エクスポータ (Phoenix / Langfuse を使う時のみ)
# Phoenix: http://localhost:6006/v1/traces
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SAMPLING_RATIO=1.0
