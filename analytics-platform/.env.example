# 環境識別 (local/gcp)
ENV=local

# このサービスの識別子 (業務ログ event.service_name に入る)
SERVICE_NAME=analytics-platform-demo
SERVICE_VERSION=0.1.0

# ログ出力先ルート (raw JSONL / payloads / uploaded / dead_letter のサブツリーを掘る)
ANALYTICS_DATA_DIR=./data

# JSONL 圧縮 (local は無圧縮のほうがデバッグしやすい)
ANALYTICS_COMPRESS=false

# コンテンツ直埋め / URI 参照 切替の閾値 (bytes)
CONTENT_INLINE_THRESHOLD_BYTES=8192

# OTel 送信先
# local: Phoenix (http://localhost:6006/v1/traces)
# gcp: Langfuse の OTLP endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:6006/v1/traces
OTEL_EXPORTER_OTLP_HEADERS=

# サンプリング率 (0.0 - 1.0)。業務ログは 100% 固定。
OTEL_SAMPLING_RATIO=1.0

# ログレベル
LOG_LEVEL=INFO

# ============================================================================
# GCP 連携 (Phase 5)。Local だけで使う場合は未設定でよい。
# ============================================================================
# JSONL upload / payload 書き出しの backend。`local` (既定) | `gcs`。
ANALYTICS_STORAGE_BACKEND=local

# GCS (gcs backend 時に必須)
ANALYTICS_GCS_BUCKET=
ANALYTICS_GCS_RAW_PREFIX=uploaded/
ANALYTICS_GCS_PAYLOAD_PREFIX=payloads/

# GCP project (Cloud Run + Workload Identity なら省略可)
ANALYTICS_GCP_PROJECT=

# BigQuery (dbt --target gcp 時に必須)
ANALYTICS_BQ_PROJECT=
ANALYTICS_BQ_LOCATION=US
ANALYTICS_BQ_RAW_DATASET=analytics_raw
ANALYTICS_BQ_STAGING_DATASET=analytics_staging
ANALYTICS_BQ_MARTS_DATASET=analytics_marts
ANALYTICS_BQ_DEFAULT_DATASET=analytics_staging
ANALYTICS_BQ_RAW_TABLE=agent_events_external
