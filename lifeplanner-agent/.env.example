# アプリ設定
APP_ENV=local
LOG_LEVEL=info

# データディレクトリ
DATA_DIR=data
MF_CSV_DIR=data/mf_csv

# Phase 3 以降で利用
# CLAUDE_CODE_OAUTH_TOKEN=
# BRAVE_API_KEY=

# LLM プロバイダ選択: "anthropic" (API 直) | "vertex" (GCP Vertex AI 経由)
# LLM_PROVIDER=anthropic

# LLM モデル (Anthropic API 形式 または Vertex 形式 "claude-sonnet-4-6@20250929")
# LLM_MODEL=claude-sonnet-4-6
# LLM_MAX_TOKENS=1200

# LLM_PROVIDER=anthropic のとき必須
# ANTHROPIC_API_KEY=

# LLM_PROVIDER=vertex のとき必須 (ADC を使用: gcloud auth application-default login)
# GOOGLE_CLOUD_PROJECT=
# VERTEX_AI_LOCATION=us-east5

# LLM をモック化してオフライン/テスト実行
# LLM_MOCK_MODE=false

# Phase 0 では DB 未接続
# DB_URL=postgresql+asyncpg://lifeplanner:password@localhost:5432/lifeplanner

# LINE 連携 (Phase 3b)
# Messaging API: Bot 署名検証 + 返信送信 + rich menu セットアップ
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_CHANNEL_SECRET=

# LIFF 認証 (Phase 3b.2): /liff/link.html + /api/line/liff-login
# LIFF アプリ ID (LINE Developers で作成)
# LIFF_ID=1234567890-abcdefgh
# LINE Login チャネル ID (ID トークンの aud クレーム検証に使用)
# LINE_LOGIN_CHANNEL_ID=1234567890

# ── 分析基盤 (analytics-platform) 連携 ──────────────────────────
# false にすると AnalyticsLogger が NoOpSink になり、JSONL は書かれない
ANALYTICS_ENABLED=true

# JSONL 書込先 (デフォルト: lifeplanner-agent 自身の data 配下)
ANALYTICS_DATA_DIR=./data/analytics

# 業務ログ送信時の service_name (Hive パーティションキー)
ANALYTICS_SERVICE_NAME=lifeplanner-agent

# JSONL の gzip 圧縮 (local は false 推奨、デバッグしやすい)
ANALYTICS_COMPRESS=false

# コンテンツ inline / URI 振り分け閾値 (bytes)
ANALYTICS_CONTENT_INLINE_THRESHOLD_BYTES=8192

# OTel エクスポータ (Phoenix を使う時のみ)
# Phoenix: http://localhost:6006/v1/traces
# 未設定でもアプリは動く (OTel は失敗してリトライ後諦めるだけ)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SAMPLING_RATIO=1.0
SERVICE_VERSION=0.1.0

# ── 分析基盤 GCP backend (Phase 5 Step 10) ─────────────────────
# `local` (既定、ローカル FS のみ) または `gcs` (Cloud Run + Workload Identity)
ANALYTICS_STORAGE_BACKEND=local

# `gcs` 指定時のみ意味を持つ env (analytics_platform.gcp_config が読む)
# GCS バケットは analytics-platform/terraform/gcs.tf で作成済の名前を入れる
ANALYTICS_GCS_BUCKET=
ANALYTICS_GCS_RAW_PREFIX=uploaded/
ANALYTICS_GCS_PAYLOAD_PREFIX=payloads/
ANALYTICS_GCP_PROJECT=

# 周期的に LocalUploader.run_once() を回す間隔 (秒)
# 0 以下にすると shutdown 時のみ 1 回 upload する
ANALYTICS_UPLOAD_INTERVAL_SECONDS=300
