# アプリ設定
APP_ENV=local
LOG_LEVEL=info

# データディレクトリ
DATA_DIR=data
MF_CSV_DIR=data/mf_csv

# Phase 3 以降で利用
# CLAUDE_CODE_OAUTH_TOKEN=
# BRAVE_API_KEY=

# LLM プロバイダ選択: "anthropic" (API 直) | "vertex" (GCP Vertex AI 経由)
# LLM_PROVIDER=anthropic

# LLM モデル (Anthropic API 形式 または Vertex 形式 "claude-sonnet-4-6@20250929")
# LLM_MODEL=claude-sonnet-4-6
# LLM_MAX_TOKENS=1200

# LLM_PROVIDER=anthropic のとき必須
# ANTHROPIC_API_KEY=

# LLM_PROVIDER=vertex のとき必須 (ADC を使用: gcloud auth application-default login)
# GOOGLE_CLOUD_PROJECT=
# VERTEX_AI_LOCATION=us-east5

# LLM をモック化してオフライン/テスト実行
# LLM_MOCK_MODE=false

# Phase 0 では DB 未接続
# DB_URL=postgresql+asyncpg://lifeplanner:password@localhost:5432/lifeplanner

# LINE 連携（Phase 3）
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_CHANNEL_SECRET=
