# Claude Code OAuth Token (required)
CLAUDE_CODE_OAUTH_TOKEN=your_claude_code_oauth_token_here

# Brave Search API Key (optional, for news sentiment analysis)
BRAVE_API_KEY=your_brave_api_key_here

# Google Cloud Project (for VertexAI)
GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# VertexAI location
VERTEX_AI_LOCATION=us-east5

# Security Platform MCP Proxy URL (optional)
# MCP_PROXY_URL=http://localhost:8080

# App settings
APP_ENV=local
LOG_LEVEL=debug

# Data paths (defaults work for local dev)
# DB_PATH=data/stock_analysis.db
# DATA_DIR=data
# CHARTS_DIR=data/charts
# REPORTS_DIR=data/reports
# CACHE_DIR=data/cache
# DICTIONARIES_DIR=data/dictionaries

# ── 分析基盤 (analytics-platform) 連携 ──────────────────────────
# false にすると AnalyticsLogger が NoOpSink になり、JSONL は書かれない
ANALYTICS_ENABLED=true

# JSONL 書込先 (デフォルト: stock-analysis-agent 自身の data 配下)
# 既存の analytics-platform/data/raw/ に直接吐きたい場合は
# ../analytics-platform/data などに変更
ANALYTICS_DATA_DIR=./data/analytics

# 業務ログ送信時の service_name (Hive パーティションキー)
ANALYTICS_SERVICE_NAME=stock-analysis-agent

# JSONL の gzip 圧縮 (local は false 推奨、デバッグしやすい)
ANALYTICS_COMPRESS=false

# コンテンツ inline / URI 振り分け閾値 (bytes)
ANALYTICS_CONTENT_INLINE_THRESHOLD_BYTES=8192

# OTel エクスポータ (Phoenix を使う時のみ)
# Phoenix: http://localhost:6006/v1/traces
# 未設定でもアプリは動く (OTel は失敗してリトライ後諦めるだけ)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:6006/v1/traces
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SAMPLING_RATIO=1.0
