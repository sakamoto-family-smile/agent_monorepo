# Anthropic API Key (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Brave Search API Key (optional, for news sentiment analysis)
BRAVE_API_KEY=your_brave_api_key_here

# Google Cloud Project (for VertexAI)
GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# VertexAI location
VERTEX_AI_LOCATION=us-east5

# Security Platform MCP Proxy URL (optional)
# MCP_PROXY_URL=http://localhost:8080

# App settings
APP_ENV=local
LOG_LEVEL=debug

# Data paths (defaults work for local dev)
# DB_PATH=data/stock_analysis.db
# DATA_DIR=data
# CHARTS_DIR=data/charts
# REPORTS_DIR=data/reports
# CACHE_DIR=data/cache
# DICTIONARIES_DIR=data/dictionaries
