# Copy to terraform.tfvars and fill in values.

project_id = "sakamoto-family-agent"
region     = "asia-northeast1"

# 名前空間。bucket / SA / secret 名のプレフィックスになる
name_prefix = "driving-license-bot"

# Cloud Run line-bot
line_bot_min_instances = 1
line_bot_max_instances = 3
line_bot_cpu           = "1"
line_bot_memory        = "512Mi"

# 初回 apply 時は image を空にして基盤だけ作る。
# Cloud Build で push した後 ↓ を埋めて apply し直すと service が deploy される。
# line_bot_image = "asia-northeast1-docker.pkg.dev/sakamoto-family-agent/driving-license-bot/line-bot:latest"
line_bot_image = ""

# LINE Webhook はパブリックなので allUsers 既定。
line_bot_invoker_members = ["allUsers"]

# Firestore. 一度作ると location は変更不可。
firestore_location = "asia-northeast1"

# 安全装置: dev/PoC では terraform destroy で完全削除できる設定にする。
# 本番化する際は両方 false → true に変える。
force_destroy       = true
deletion_protection = false

# ---- Cloud SQL (Phase 2-A) ----
# db-f1-micro: shared CPU, 0.6GB RAM, 月 ~$10
cloudsql_tier                = "db-f1-micro"
cloudsql_disk_size_gb        = 10
cloudsql_deletion_protection = false
cloudsql_backup_enabled      = true
# Cloud SQL Auth Proxy 経由で接続する想定なので authorized_networks は空。
# 一時的に直接接続したい場合のみ追加（IPv4 CIDR）:
# cloudsql_authorized_networks = [{ name = "office", value = "203.0.113.0/24" }]
cloudsql_authorized_networks = []

# ---- Workload Identity Federation (CI で `terraform plan` を回す用) ----
# 1. 初回 apply は false で OK（基盤のみ作る）。
# 2. tfstate_bucket を bootstrap で作ったバケット名に書き、enable_wif=true で再 apply。
# 3. `make tf-output-wif` で取れる値を GitHub repo の Variables に登録。
enable_wif     = false
github_repo    = "sakamoto-family-smile/agent_monorepo"
tfstate_bucket = "sakamoto-family-agent-driving-license-bot-tfstate"
