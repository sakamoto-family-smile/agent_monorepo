# LINE 認証情報を一括投入するためのテンプレート。
# 値を埋めて `.env.secrets` にリネーム（このリポでは git ignored）し、
# `make secrets-push` で Secret Manager に投入する。
#
# 値はクォートで囲まなくて OK（push スクリプトが安全に渡す）。
# `=` 周りに余計な空白を入れない。コメント (#) は行頭のみ。

# 必須（Phase 1 の動作に最低限）
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# 任意（Phase 1 でも使えると運営者通知が便利）
# LINE で「U + 32 文字英数字」を CSV で。例: Uxxxxx,Uyyyyy
OPERATOR_LINE_USER_IDS=

# 任意（Phase 2+ で複数 Bot 名寄せ用 LINE Login プロバイダを作ったら）
LINE_LOGIN_CHANNEL_SECRET=
