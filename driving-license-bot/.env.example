# ---- Service identity (used by analytics-platform) ----
SERVICE_NAME=driving-license-bot-line   # line-bot / agent / batch / admin で個別に設定
SERVICE_VERSION=0.1.0
ENV=local                                # local | gcp

# ---- LINE Messaging API ----
LINE_CHANNEL_SECRET=                     # 必須（Secret Manager 経由が望ましい）
LINE_CHANNEL_ACCESS_TOKEN=               # 必須（Secret Manager 経由が望ましい）
# 運営者宛の通知用（自分の LINE User ID を入れる）
OPERATOR_LINE_USER_IDS=                  # CSV 例: Uxxxx,Uyyyy

# ---- LINE Login (Phase 1 では未使用、フィールドだけ予約) ----
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=

# ---- GCP / Vertex AI ----
GOOGLE_CLOUD_PROJECT=                    # 必須
ANTHROPIC_VERTEX_PROJECT_ID=             # 通常 GOOGLE_CLOUD_PROJECT と同じ
CLOUD_ML_REGION=asia-northeast1          # Phase 0 確定: Tokyo（Anthropic Claude フル対応）
VERTEX_CLAUDE_MODEL=claude-opus-4-7      # Question Generator / Tutor 用
VERTEX_GEMINI_MODEL=gemini-2.5-pro       # Quality Reviewer cross-check 用

# ---- Cloud SQL (pgvector for question-bank dedup) ----
CLOUDSQL_INSTANCE_CONNECTION_NAME=       # project:region:instance
CLOUDSQL_DB=question_bank
CLOUDSQL_USER=app
CLOUDSQL_PASSWORD_SECRET=driving-license-bot-cloudsql-password    # Secret Manager 名
EMBEDDING_MODEL=text-embedding-004       # Vertex AI 標準（768 次元）
EMBEDDING_DIM=768

# ---- Firestore ----
FIRESTORE_DATABASE=(default)             # マルチデータベース時に変更

# ---- Cloud Tasks ----
CLOUD_TASKS_QUEUE=driving-license-bot-jobs
CLOUD_TASKS_LOCATION=asia-northeast1
CLOUD_TASKS_INVOKER_SA=                  # worker を invoke する SA email

# ---- analytics-platform 連携 ----
ANALYTICS_DATA_DIR=./data
ANALYTICS_STORAGE_BACKEND=local          # local | gcs
ANALYTICS_GCS_BUCKET=                    # gcs 時に必須（analytics-platform と共用）
ANALYTICS_GCS_RAW_PREFIX=uploaded/
ANALYTICS_GCS_PAYLOAD_PREFIX=payloads/

# ---- OTel / Langfuse（analytics-platform と整合） ----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:6006/v1/traces
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SAMPLING_RATIO=1.0

# ---- security-platform / MCP Proxy ----
# agent-service が叩く .mcp.json は HTTP transport で proxy を指す
SECURITY_MCP_PROXY_URL=http://localhost:8080
SECURITY_MCP_PROXY_MODE=passive          # passive | active

# ---- 問題プール / 生成設定 ----
QUESTION_POOL_MIN_SIZE=200               # これを下回ると運営者にアラート
QUESTION_POOL_TARGET_SIZE=500
GENERATION_BATCH_SIZE=20                 # 1 回の Cloud Run Job 起動で生成する件数

# ---- レビュー Web UI ----
REVIEW_ADMIN_ALLOWED_EMAILS=             # CSV、IAP で許可する Google アカウント

# ---- ロギング ----
LOG_LEVEL=INFO
